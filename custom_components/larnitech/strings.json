{
  "config": {
    "step": {
      "user": {
        "title": "Connect to Larnitech controller",
        "description": "Enter the IP address and API key for your Larnitech controller. The API key can be found in LT Setup → Plugins → API → Configure.",
        "data": {
          "host": "[%key:common::config_flow::data::host%]",
          "api_key": "API key",
          "ws_port": "WebSocket port",
          "http_port": "HTTP API port"
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    }
  },
  "entity": {
    "climate": {
      "larnitech_ac": {
        "state_attributes": {
          "fan_mode": {
            "state": {
              "Turbo": "Turbo",
              "Night": "Night"
            }
          },
          "swing_mode": {
            "state": {
              "Auto": "Auto",
              "1": "Position 1",
              "2": "Position 2",
              "3": "Position 3",
              "4": "Position 4",
              "5": "Position 5",
              "6": "Position 6",
              "7": "Position 7",
              "8": "Position 8"
            }
          },
          "swing_horizontal_mode": {
            "state": {
              "0": "Position 0",
              "1": "Position 1",
              "2": "Position 2",
              "3": "Position 3",
              "4": "Position 4",
              "5": "Position 5",
              "6": "Position 6",
              "7": "Position 7",
              "8": "Position 8"
            }
          }
        }
      }
    }
  }
}
